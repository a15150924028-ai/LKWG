.field-picker {
  box-sizing: border-box;
  position: relative;
  min-width: 0;
  margin-top: 12rpx;
}

.identity-grid .field-picker,
.talent-grid .field-picker {
  margin-top: 0;
}

.field-frame {
  box-sizing: border-box;
  min-width: 0;
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(190, 205, 225, 0.55);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.68);
  box-shadow: inset 0 0 0 2rpx rgba(77, 163, 255, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.field-picker.disabled .field-frame {
  background: rgba(138, 150, 168, 0.12);
  opacity: 0.66;
}

.field-label-chip {
  position: absolute;
  top: -11rpx;
  left: 16rpx;
  z-index: 1;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #5F6B7A;
  font-size: 21rpx;
  line-height: 1.2;
}

.field-content-row,
.search-control {
  display: flex;
  align-items: center;
  min-height: 40rpx;
  min-width: 0;
}

.option-icon-image,
.option-icon-text {
  flex: none;
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
  border-radius: 10rpx;
}

.option-icon-image {
  display: block;
  box-sizing: border-box;
  padding: 3rpx;
  border: 1rpx solid rgba(190, 205, 225, 0.55);
  background: rgba(255, 255, 255, 0.58);
  object-fit: contain;
  object-position: center;
  align-self: center;
  transform-origin: center;
}

.type-icon-image {
  border-radius: 50%;
  border: 0;
  background: transparent;
  padding: 0;
}

.bloodline-icon-image {
  border-radius: 8rpx;
}

.stat-icon-image {
  width: 32rpx;
  height: 32rpx;
  border-radius: 0;
}

.stat-atk-icon {
  transform: translate(-2rpx, 2rpx) scale(1.14);
}

.option-icon-text {
  border: 1rpx solid rgba(190, 205, 225, 0.55);
  background: rgba(255, 255, 255, 0.58);
  color: #5F6B7A;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
}

.field-value {
  flex: 1;
  min-width: 0;
  height: 40rpx;
  color: #1F2633;
  font-size: 25rpx;
  font-weight: 560;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field-value.placeholder {
  color: #8A96A8;
  font-weight: 400;
}

.edit-trigger,
.clear-button,
.search-mark {
  flex: none;
  width: 36rpx;
  margin-left: 6rpx;
  color: #8A96A8;
  font-size: 25rpx;
  line-height: 36rpx;
  text-align: center;
}

.edit-trigger {
  font-size: 24rpx;
}

.compact {
  margin-top: 10rpx;
}

.compact .field-frame {
  padding: 8rpx 10rpx;
  border-radius: 14rpx;
}

.compact .field-label-chip {
  font-size: 19rpx;
  left: 12rpx;
}

.compact .field-value {
  font-size: 23rpx;
}
