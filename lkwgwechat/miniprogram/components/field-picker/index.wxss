.field-picker {
  box-sizing: border-box;
  min-width: 0;
  margin-top: 14rpx;
  padding: 12rpx 16rpx 10rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 16rpx;
  background: #ffffff;
}

.identity-grid .field-picker,
.talent-grid .field-picker {
  margin-top: 0;
}

.field-picker.disabled {
  background: #f2f4f7;
  opacity: 0.66;
}

.field-label {
  display: block;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.2;
}

.search-control {
  display: flex;
  align-items: center;
  min-height: 48rpx;
}

.option-icon-image,
.option-icon-text {
  flex: none;
  width: 34rpx;
  height: 34rpx;
  margin-right: 8rpx;
  border-radius: 8rpx;
}

.option-icon-image {
  background: transparent;
}

.option-icon-text {
  background: #eef2f7;
  color: #475467;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}

.field-input {
  flex: 1;
  min-width: 0;
  height: 48rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 560;
  line-height: 48rpx;
}

.field-input::placeholder {
  color: #98a2b3;
  font-weight: 400;
}

.clear-button,
.search-mark {
  flex: none;
  width: 44rpx;
  margin-left: 6rpx;
  color: #98a2b3;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
}

.suggestion-list {
  max-height: 440rpx;
  margin: 8rpx -4rpx 2rpx;
  overflow-y: auto;
  border-top: 1rpx solid #edf0f5;
}

.suggestion-item,
.empty-result {
  display: flex;
  align-items: center;
  padding: 16rpx 8rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.35;
}

.suggestion-copy {
  min-width: 0;
}

.suggestion-label,
.suggestion-detail {
  display: block;
}

.suggestion-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-detail {
  margin-top: 2rpx;
  color: #667085;
  font-size: 21rpx;
}

.suggestion-item + .suggestion-item {
  border-top: 1rpx solid #f0f2f5;
}

.suggestion-item:active {
  background: #eef5ff;
  color: #1677ff;
}

.empty-result {
  color: #98a2b3;
  text-align: center;
}

.compact {
  padding-right: 10rpx;
  padding-left: 10rpx;
}

.compact .field-label {
  font-size: 19rpx;
}

.compact .field-input,
.compact .suggestion-item,
.compact .empty-result {
  font-size: 23rpx;
}
