.field-picker {
  box-sizing: border-box;
  position: relative;
  min-width: 0;
  margin-top: 14rpx;
  padding: 12rpx 16rpx 10rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 16rpx;
  background: #ffffff;
}

.identity-grid .field-picker,
.talent-grid .field-picker {
  margin-top: 0;
}

.field-picker.disabled {
  background: #f2f4f7;
  opacity: 0.66;
}

.field-label {
  display: block;
  color: #667085;
  font-size: 21rpx;
  line-height: 1.2;
}

.search-control {
  display: flex;
  align-items: center;
  min-height: 48rpx;
}

.option-icon-image,
.option-icon-text {
  flex: none;
  width: 34rpx;
  height: 34rpx;
  margin-right: 8rpx;
  border-radius: 8rpx;
}

.option-icon-image {
  display: block;
  background: transparent;
  object-fit: contain;
  object-position: center;
  align-self: center;
  transform-origin: center;
}

.type-icon-image {
  border-radius: 50%;
}

.bloodline-icon-image {
  border-radius: 8rpx;
}

.stat-icon-image {
  width: 32rpx;
  height: 32rpx;
  border-radius: 0;
}

.stat-atk-icon {
  transform: translate(-2rpx, 2rpx) scale(1.14);
}

.option-icon-text {
  background: #eef2f7;
  color: #475467;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}

.field-value {
  flex: 1;
  min-width: 0;
  height: 48rpx;
  color: #172033;
  font-size: 27rpx;
  font-weight: 560;
  line-height: 48rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field-value.placeholder {
  color: #98a2b3;
  font-weight: 400;
}

.clear-button,
.search-mark {
  flex: none;
  width: 44rpx;
  margin-left: 6rpx;
  color: #98a2b3;
  font-size: 28rpx;
  line-height: 44rpx;
  text-align: center;
}

.compact {
  padding-right: 10rpx;
  padding-left: 10rpx;
}

.compact .field-label {
  font-size: 19rpx;
}

.compact .field-value {
  font-size: 23rpx;
}
