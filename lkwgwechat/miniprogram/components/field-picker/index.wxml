<view class="field-picker {{compact ? 'compact' : ''}} {{disabled ? 'disabled' : ''}} {{focused ? 'focused' : ''}}">
  <text class="field-label">{{label}}</text>
  <view class="search-control">
    <image
      wx:if="{{selectedOption.icon}}"
      class="option-icon-image {{selectedOption.iconClass}}"
      src="{{selectedOption.icon}}"
      mode="aspectFit"
    />
    <text
      wx:elif="{{selectedOption.iconText}}"
      class="option-icon-text"
    >{{selectedOption.iconText}}</text>
    <input
      class="field-input"
      value="{{query}}"
      placeholder="{{valueIndex === 0 ? valueLabel : '输入搜索'}}"
      disabled="{{disabled}}"
      confirm-type="done"
      bindfocus="onFocus"
      bindinput="onInput"
      bindblur="onBlur"
    />
    <text
      wx:if="{{query && !disabled}}"
      class="clear-button"
      bindtap="onClear"
    >×</text>
    <text wx:else class="search-mark">⌕</text>
  </view>

  <view wx:if="{{focused}}" class="suggestion-list">
    <block wx:if="{{suggestions.length}}">
      <view
        wx:for="{{suggestions}}"
        wx:key="id"
        class="suggestion-item"
        data-index="{{item.index}}"
        bindtap="onSelect"
      >
        <image
          wx:if="{{item.icon}}"
          class="option-icon-image {{item.iconClass}}"
          src="{{item.icon}}"
          mode="aspectFit"
        />
        <text
          wx:elif="{{item.iconText}}"
          class="option-icon-text"
        >{{item.iconText}}</text>
        <view class="suggestion-copy">
          <text class="suggestion-label">{{item.label}}</text>
        </view>
      </view>
    </block>
    <text wx:else class="empty-result">没有匹配项</text>
  </view>
</view>
