.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 10rpx;
}

.stat-cell {
  min-width: 0;
  padding: 9rpx 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.46);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.50), rgba(255, 255, 255, 0.38));
  text-align: center;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86), inset 0 -1rpx 0 rgba(255, 255, 255, 0.28);
}

.stat-inline-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.stat-cell.nature-up {
  background: rgba(53, 212, 155, 0.14);
}

.stat-cell.nature-down {
  box-shadow: inset 0 0 0 2rpx rgba(255, 107, 122, 0.28);
}

.stat-label-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  color: #5F6B7A;
  font-size: 20rpx;
}

.stat-value {
  font-size: 26rpx;
  font-weight: 720;
  color: #1F2633;
}

.nature-arrow,
.talent-mark {
  font-weight: 900;
}

.nature-arrow.up,
.talent-mark {
  color: #1FAE7A;
}

.nature-arrow.down {
  color: #E85A6A;
}

.talent-mark {
  font-size: 25rpx;
}
