<view class="stat-grid">
  <block wx:for="{{rows}}" wx:key="key" wx:for-item="row">
    <view class="stat-cell {{row.natureUp ? 'nature-up' : ''}} {{row.natureDown ? 'nature-down' : ''}}">
      <view class="stat-label-row">
        <text>{{row.label}}</text>
        <text wx:if="{{row.natureUp}}" class="nature-arrow up">↑</text>
        <text wx:if="{{row.natureDown}}" class="nature-arrow down">↓</text>
        <text wx:if="{{row.talented}}" class="talent-mark">＋</text>
      </view>
      <text class="stat-value">{{row.value}}</text>
    </view>
  </block>
</view>
