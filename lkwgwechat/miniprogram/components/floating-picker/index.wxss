.floating-picker-root {
  position: fixed;
  inset: 0;
  z-index: 1000;
  pointer-events: auto;
}

.floating-picker-mask {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.18);
}

.floating-picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  box-sizing: border-box;
  padding: 10rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 44rpx rgba(16, 24, 40, 0.18);
}

.floating-picker-grip {
  width: 70rpx;
  height: 8rpx;
  margin: 0 auto 8rpx;
  border-radius: 999rpx;
  background: #cfd6e1;
}

.floating-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.floating-picker-title {
  color: #172033;
  font-size: 30rpx;
  font-weight: 700;
}

.floating-picker-close {
  width: 54rpx;
  height: 54rpx;
  color: #172033;
  font-size: 34rpx;
  line-height: 54rpx;
  text-align: center;
}

.floating-picker-input-row {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  height: 68rpx;
  padding: 0 18rpx;
  border: 2rpx solid #84b8ff;
  border-radius: 12rpx;
  background: #ffffff;
}

.floating-picker-search {
  flex: none;
  width: 40rpx;
  color: #98a2b3;
  font-size: 28rpx;
  line-height: 40rpx;
}

.floating-picker-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  color: #172033;
  font-size: 27rpx;
  line-height: 64rpx;
}

.floating-picker-list {
  max-height: 360rpx;
  margin-top: 10rpx;
  overflow-y: auto;
}

.floating-picker-item,
.floating-picker-empty {
  display: flex;
  align-items: center;
  min-height: 66rpx;
  box-sizing: border-box;
  padding: 10rpx 6rpx;
  border-bottom: 1rpx solid #edf0f5;
  color: #344054;
  font-size: 28rpx;
}

.floating-picker-item:active {
  background: #eef5ff;
  color: #1677ff;
}

.floating-picker-label {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.floating-picker-empty {
  justify-content: center;
  color: #98a2b3;
}

.option-icon-image,
.option-icon-text {
  flex: none;
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  border-radius: 8rpx;
}

.option-icon-image {
  display: block;
  background: transparent;
  object-fit: contain;
  object-position: center;
  align-self: center;
  transform-origin: center;
}

.type-icon-image {
  border-radius: 50%;
}

.bloodline-icon-image {
  border-radius: 8rpx;
}

.stat-icon-image {
  width: 32rpx;
  height: 32rpx;
  border-radius: 0;
}

.stat-atk-icon {
  transform: translate(-2rpx, 2rpx) scale(1.14);
}

.option-icon-text {
  background: #eef2f7;
  color: #475467;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}
