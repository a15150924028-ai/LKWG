.floating-picker-root {
  position: fixed;
  inset: 0;
  z-index: 1000;
  pointer-events: auto;
}

.floating-picker-mask {
  position: absolute;
  inset: 0;
  background: rgba(31, 38, 51, 0.22);
}

.floating-picker-panel {
  position: fixed;
  left: 0;
  right: 0;
  box-sizing: border-box;
  padding: 10rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-bottom: 0;
  border-radius: 56rpx 56rpx 0 0;
  background: rgba(255, 255, 255, 0.76);
  background-image: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 255, 255, 0.68)), radial-gradient(circle at 86% 0%, rgba(108, 99, 255, 0.08), rgba(108, 99, 255, 0) 44%);
  box-shadow: 0 -22rpx 52rpx rgba(90, 110, 180, 0.22), inset 0 1rpx 0 rgba(255, 255, 255, 0.90), inset 0 -1rpx 0 rgba(255, 255, 255, 0.34);
}

.floating-picker-grip {
  width: 70rpx;
  height: 8rpx;
  margin: 0 auto 8rpx;
  border-radius: 999rpx;
  background: rgba(138, 150, 168, 0.42);
}

.floating-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.floating-picker-title {
  color: #1F2633;
  font-size: 30rpx;
  font-weight: 700;
}

.floating-picker-close {
  width: 54rpx;
  height: 54rpx;
  color: #1F2633;
  font-size: 34rpx;
  line-height: 54rpx;
  text-align: center;
}

.floating-picker-input-row {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  height: 68rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(77, 163, 255, 0.65);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.56);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.64), rgba(255, 255, 255, 0.50));
  box-shadow: 0 0 0 6rpx rgba(77, 163, 255, 0.12);
}

.floating-picker-search {
  flex: none;
  width: 40rpx;
  color: #8A96A8;
  font-size: 28rpx;
  line-height: 40rpx;
}

.floating-picker-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  color: #1F2633;
  font-size: 27rpx;
  line-height: 64rpx;
}

.floating-picker-list {
  max-height: 360rpx;
  margin-top: 10rpx;
  overflow-y: auto;
}

.floating-picker-item,
.floating-picker-empty {
  display: flex;
  align-items: center;
  min-height: 66rpx;
  box-sizing: border-box;
  padding: 10rpx 6rpx;
  border-bottom: 1rpx solid rgba(190, 205, 225, 0.28);
  color: #1F2633;
  font-size: 28rpx;
}

.floating-picker-item:active {
  background: linear-gradient(135deg, rgba(108, 99, 255, 0.12), rgba(70, 216, 207, 0.10));
  color: #4DA3FF;
}

.floating-picker-label {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.floating-picker-empty {
  justify-content: center;
  color: #8A96A8;
}

.option-icon-image,
.option-icon-text {
  flex: none;
  width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  border-radius: 8rpx;
}

.option-icon-image {
  display: block;
  background: transparent;
  object-fit: contain;
  object-position: center;
  align-self: center;
  transform-origin: center;
}

.type-icon-image {
  border-radius: 50%;
}

.bloodline-icon-image {
  border-radius: 8rpx;
}

.stat-icon-image {
  width: 32rpx;
  height: 32rpx;
  border-radius: 0;
}

.stat-atk-icon {
  transform: translate(-2rpx, 2rpx) scale(1.14);
}

.option-icon-text {
  background: rgba(255, 255, 255, 0.46);
  color: #5F6B7A;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}
