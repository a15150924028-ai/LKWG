page {
  min-height: 100%;
  background: linear-gradient(180deg, #F7F8FF 0%, #EEF7FF 45%, #F8FFFB 100%);
  color: #1F2633;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
}

.page {
  box-sizing: border-box;
  position: relative;
  z-index: 0;
  min-height: 100vh;
  padding: 28rpx 28rpx 0;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.page::before,
.page::after {
  content: "";
  position: fixed;
  z-index: 0;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  filter: blur(44rpx);
  pointer-events: none;
}

.page::before {
  top: 18rpx;
  right: -130rpx;
  background: rgba(120, 190, 255, 0.28);
}

.page::after {
  left: -140rpx;
  bottom: 90rpx;
  background: rgba(80, 230, 200, 0.18);
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 10rpx 28rpx rgba(80, 110, 160, 0.14), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.hero::after {
  content: "";
  position: absolute;
  right: 24rpx;
  top: 18rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: rgba(170, 130, 255, 0.22);
  filter: blur(30rpx);
  pointer-events: none;
}

.hero-title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-description {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  color: #5F6B7A;
  font-size: 26rpx;
  line-height: 1.6;
}

.status-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 10rpx 28rpx rgba(80, 110, 160, 0.14), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.status-title {
  display: block;
  font-size: 30rpx;
  font-weight: 650;
}

.status-text {
  display: block;
  margin-top: 10rpx;
  color: #5F6B7A;
  font-size: 25rpx;
  line-height: 1.55;
}

.primary-button {
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7C6DFF 0%, #4DA3FF 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(108, 99, 255, 0.28);
}

.primary-button::after {
  border: 0;
}
