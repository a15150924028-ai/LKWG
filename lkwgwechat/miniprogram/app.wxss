page {
  min-height: 100%;
  background: #f5f7fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
}

.hero {
  padding: 30rpx;
  border: 1rpx solid #e4e9f2;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(37, 51, 82, 0.08);
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-description {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.6;
}

.status-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #dfe6f1;
  border-radius: 24rpx;
  background: #ffffff;
}

.status-title {
  display: block;
  font-size: 30rpx;
  font-weight: 650;
}

.status-text {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
}

.primary-button {
  margin-top: 22rpx;
  border-radius: 18rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-button::after {
  border: 0;
}
