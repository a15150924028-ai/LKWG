page {
  min-height: 100%;
  background: linear-gradient(180deg, #F8FAFC 0%, #F4F7FB 100%);
  color: #1F2633;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", system-ui, sans-serif;
}

.page {
  box-sizing: border-box;
  position: relative;
  z-index: 0;
  min-height: 100vh;
  padding: 28rpx 28rpx 0;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.page::before,
.page::after {
  content: "";
  position: fixed;
  z-index: 0;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  filter: blur(56rpx);
  opacity: 1;
  pointer-events: none;
}

.page::before {
  top: 12rpx;
  right: -150rpx;
  background: rgba(77, 163, 255, 0.12);
}

.page::after {
  left: -150rpx;
  bottom: 120rpx;
  background: rgba(70, 216, 207, 0.07);
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 34rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 48rpx;
  background: rgba(255, 255, 255, 0.52);
  backdrop-filter: blur(24rpx);
  box-shadow: 0 16rpx 40rpx rgba(80, 110, 160, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.90), inset 0 -1rpx 0 rgba(255, 255, 255, 0.36);
}

.hero::after {
  content: "";
  position: absolute;
  right: 24rpx;
  top: 20rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: rgba(108, 99, 255, 0.10);
  filter: blur(38rpx);
  pointer-events: none;
}

.hero-title {
  position: relative;
  z-index: 1;
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-description {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 12rpx;
  color: #5F6B7A;
  font-size: 26rpx;
  line-height: 1.6;
}

.status-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.52);
  backdrop-filter: blur(24rpx);
  box-shadow: 0 16rpx 40rpx rgba(80, 110, 160, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.90), inset 0 -1rpx 0 rgba(255, 255, 255, 0.36);
}

.status-title {
  display: block;
  font-size: 30rpx;
  font-weight: 650;
}

.status-text {
  display: block;
  margin-top: 10rpx;
  color: #5F6B7A;
  font-size: 25rpx;
  line-height: 1.55;
}

.primary-button {
  margin-top: 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7C6DFF 0%, #4DA3FF 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(108, 99, 255, 0.28);
}

.primary-button::after {
  border: 0;
}
