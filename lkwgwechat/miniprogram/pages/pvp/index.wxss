.weather-card,
.side-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.62);
  backdrop-filter: blur(18rpx);
  box-shadow: 0 10rpx 28rpx rgba(80, 110, 160, 0.14), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.section-title,
.side-title {
  font-size: 29rpx;
  font-weight: 700;
}

.weather-grid,
.preset-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 0;
}

.weather-button,
.clear-side {
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  margin: 0;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #5F6B7A;
  font-size: 23rpx;
}

.weather-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  overflow: hidden;
  gap: 8rpx;
  min-height: 58rpx;
}

.weather-icon {
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 auto;
}

.weather-icon-text {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.weather-button::after,
.preset-button::after,
.clear-side::after,
.stepper button::after {
  border: 0;
}

.preset-button.active {
  background: linear-gradient(135deg, #7C6DFF 0%, #4DA3FF 100%);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.35);
  color: #ffffff;
}

.weather-button.active {
  color: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.35);
}

.weather-button.weather-none.active {
  background: linear-gradient(135deg, #607089, #4DA3FF);
}

.weather-button.weather-rain.active {
  background: linear-gradient(135deg, #4DA3FF, #46D8CF);
}

.weather-button.weather-sandstorm.active {
  background: linear-gradient(135deg, #FFB45C, #6C63FF);
}

.weather-button.weather-blizzard.active {
  background: linear-gradient(135deg, #8DEFE8, #4DA3FF);
}

.side-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.clear-side {
  background: rgba(255, 107, 122, 0.10);
  color: #E85A6A;
}

.identity-grid,
.talent-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.talent-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 10rpx;
}

.preset-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 12rpx;
}

.preset-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 58rpx;
  min-height: 58rpx;
  margin: 0;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: inset 0 0 0 1rpx rgba(190, 205, 225, 0.55);
  color: #5F6B7A;
}

.preset-button-label {
  display: block;
  width: 100%;
  overflow: hidden;
  color: inherit;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.default-note,
.skill-description,
.order-text {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.default-note {
  color: #d92d20;
  font-weight: 600;
}

.skill-description,
.order-text {
  color: #5F6B7A;
}

.counter-block,
.buff-control {
  min-width: 0;
  padding: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.counter-label,
.buff-control > text {
  display: block;
  overflow: hidden;
  color: #5F6B7A;
  font-size: 22rpx;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stepper {
  display: grid;
  grid-template-columns: 48rpx minmax(42rpx, 1fr) 48rpx;
  align-items: center;
  gap: 6rpx;
  margin-top: 6rpx;
  text-align: center;
}

.stepper button {
  width: 48rpx;
  min-width: 0;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #6C63FF;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.compact-control-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 10rpx;
}

.advanced-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(190, 205, 225, 0.55);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.58);
}

.advanced-toggle-title,
.advanced-toggle-subtitle {
  display: block;
}

.advanced-toggle-title {
  color: #1F2633;
  font-size: 25rpx;
  font-weight: 700;
}

.advanced-toggle-subtitle {
  margin-top: 3rpx;
  color: #5F6B7A;
  font-size: 21rpx;
}

.advanced-toggle-icon {
  flex: none;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #4DA3FF;
  font-size: 22rpx;
  font-weight: 700;
}

.skills-card,
.damage-card {
  margin-top: 12rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.54);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.skill-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 10rpx;
}

.skill-action-row {
  border-radius: 18rpx;
}

.force-action-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 10rpx;
  min-height: 60rpx;
  margin: 0;
  padding: 0 12rpx;
  border: 1rpx solid rgba(190, 205, 225, 0.55);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #5F6B7A;
  font-size: 22rpx;
  font-weight: 650;
  text-align: left;
}

.force-action-button.active {
  border: 2rpx solid rgba(77, 163, 255, 0.65);
  background: linear-gradient(135deg, rgba(108, 99, 255, 0.12), rgba(70, 216, 207, 0.10));
  color: #1F2633;
}

.force-action-button.disabled {
  color: #8A96A8;
  background: rgba(138, 150, 168, 0.12);
}

.force-action-button::after {
  border: 0;
}

.force-action-row {
  grid-column: 1 / -1;
  min-width: 0;
  margin-top: 0;
}

.force-action-icon {
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 auto;
}

.force-action-text {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  color: inherit;
  font-size: 24rpx;
  font-weight: 700;
}

.force-action-text text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.damage-card {
  background: linear-gradient(135deg, rgba(77, 163, 255, 0.13), rgba(70, 216, 207, 0.12));
  border-color: rgba(77, 163, 255, 0.35);
}

.damage-error {
  display: block;
  color: #E85A6A;
  font-size: 25rpx;
  font-weight: 650;
}

.damage-line-card {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.54);
}

.damage-card-title,
.damage-subtitle {
  display: block;
  color: #5F6B7A;
  font-size: 22rpx;
  font-weight: 700;
}

.damage-main-number {
  display: block;
  color: #6C63FF;
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.05;
}

.damage-subtitle {
  color: #4DA3FF;
}

.damage-response-variants {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.damage-response-line {
  color: #1F2633;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1.45;
}

.damage-line-meta,
.damage-line-description {
  color: #5F6B7A;
  font-size: 22rpx;
  line-height: 1.45;
}

@media (max-width: 430px) {
  .identity-grid {
    grid-template-columns: 1fr;
  }
}
