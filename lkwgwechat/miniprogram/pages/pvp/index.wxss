.weather-card,
.side-card {
  margin-top: 12rpx;
  padding: 16rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 20rpx;
  background: #ffffff;
}

.section-title,
.side-title {
  font-size: 29rpx;
  font-weight: 700;
}

.weather-grid,
.preset-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 0;
}

.weather-button,
.preset-button,
.clear-side {
  margin: 0;
  padding: 0 10rpx;
  border-radius: 14rpx;
  background: #eef2f7;
  color: #475467;
  font-size: 23rpx;
}

.weather-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 58rpx;
}

.weather-icon {
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 auto;
}

.weather-icon-text {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.weather-button::after,
.preset-button::after,
.clear-side::after,
.stepper button::after {
  border: 0;
}

.preset-button.active {
  background: #1677ff;
  color: #ffffff;
}

.weather-button.active {
  color: #ffffff;
}

.weather-button.weather-none.active {
  background: #64748b;
}

.weather-button.weather-rain.active {
  background: #3b82f6;
}

.weather-button.weather-sandstorm.active {
  background: #b0893f;
}

.weather-button.weather-blizzard.active {
  background: #4baed8;
}

.side-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.clear-side {
  background: #fff1f0;
  color: #d92d20;
}

.identity-grid,
.talent-grid,
.counter-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.talent-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 10rpx;
}

.preset-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.preset-hidden-labels {
  display: none;
}

.default-note,
.skill-description,
.order-text {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
}

.default-note {
  color: #d92d20;
  font-weight: 600;
}

.skill-description,
.order-text {
  color: #667085;
}

.counter-row {
  margin-top: 12rpx;
}

.counter-block,
.buff-control {
  padding: 8rpx 10rpx;
  border-radius: 14rpx;
  background: #f5f7fb;
}

.counter-label,
.buff-control > text {
  display: block;
  color: #475467;
  font-size: 22rpx;
}

.stepper {
  display: grid;
  grid-template-columns: 42rpx minmax(48rpx, 1fr) 42rpx;
  align-items: center;
  gap: 6rpx;
  margin-top: 6rpx;
  text-align: center;
}

.stepper button {
  width: 42rpx;
  min-width: 0;
  height: 42rpx;
  margin: 0;
  padding: 0;
  border-radius: 10rpx;
  background: #ffffff;
  color: #1677ff;
  font-size: 25rpx;
  line-height: 42rpx;
}

.buff-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 10rpx;
}

.skills-card,
.damage-card {
  margin-top: 12rpx;
  padding: 12rpx;
  border: 1rpx solid #e1e7f0;
  border-radius: 18rpx;
}

.skill-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 10rpx;
}

.skill-action-row {
  border-radius: 18rpx;
}

.skill-action-row.active {
  padding: 3rpx;
  border: 2rpx solid #1677ff;
  background: #eaf3ff;
}

.force-action-button {
  margin: 0;
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: #f2f6fb;
  color: #475467;
  font-size: 22rpx;
  font-weight: 650;
}

.force-action-button.active {
  border: 2rpx solid #1677ff;
  background: #eef6ff;
  color: #1d2939;
}

.force-action-button[disabled] {
  color: #98a2b3;
  background: #f2f4f7;
}

.force-action-button::after {
  border: 0;
}

.force-action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 10rpx;
  min-height: 60rpx;
  text-align: left;
}

.force-action-row {
  grid-column: 1 / -1;
  min-width: 0;
  margin-top: 0;
}

.force-action-icon {
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 auto;
}

.force-action-text {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  color: inherit;
  font-size: 24rpx;
  font-weight: 700;
}

.force-action-text text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.damage-card {
  background: #f8fbff;
}

.damage-error {
  display: block;
  color: #d92d20;
  font-size: 25rpx;
  font-weight: 650;
}

.damage-line-card {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 10rpx 12rpx;
  border-radius: 14rpx;
  background: #eef6ff;
}

.damage-line-title {
  color: #1d2939;
  font-size: 26rpx;
  font-weight: 720;
}

.damage-response-variants {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.damage-response-line {
  color: #1d2939;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 1.45;
}

.damage-line-meta,
.damage-line-description {
  color: #475467;
  font-size: 22rpx;
  line-height: 1.45;
}

@media (max-width: 430px) {
  .identity-grid {
    grid-template-columns: 1fr;
  }
}
