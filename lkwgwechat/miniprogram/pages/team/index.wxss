.team-toolbar {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
}

.team-count {
  display: block;
  font-size: 28rpx;
  font-weight: 650;
}

.toolbar-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.small-button {
  flex: 1;
  min-width: 190rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #eef2f7;
  color: #344054;
  font-size: 24rpx;
}

.small-button::after {
  border: 0;
}

.small-button.primary {
  background: #1677ff;
  color: #ffffff;
}

.small-button.danger {
  background: #fff1f0;
  color: #d92d20;
}

.team-overview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.team-slot {
  min-width: 0;
  min-height: 150rpx;
  margin: 0;
  padding: 14rpx;
  border: 2rpx solid #e1e7f0;
  border-radius: 18rpx;
  background: #ffffff;
  color: #344054;
  line-height: 1.3;
  text-align: left;
}

.team-slot::after {
  border: 0;
}

.team-slot.active {
  border-color: #1677ff;
  background: #eef5ff;
  box-shadow: 0 8rpx 22rpx rgba(22, 119, 255, 0.14);
}

.team-slot.complete {
  border-color: #32b36b;
}

.team-slot.active.complete {
  border-color: #1677ff;
}

.team-slot-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.team-slot-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #eef2f7;
  color: #475467;
  font-size: 20rpx;
  font-weight: 700;
}

.team-slot.active .team-slot-number {
  background: #1677ff;
  color: #ffffff;
}

.team-slot-status {
  color: #128245;
  font-size: 18rpx;
  font-weight: 650;
}

.team-slot-name {
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  font-size: 23rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-slot-types {
  display: flex;
  flex-wrap: wrap;
  gap: 5rpx;
  margin-top: 8rpx;
}

.team-slot-type {
  padding: 2rpx 7rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 17rpx;
}

.team-slot-empty {
  color: #98a2b3;
  font-size: 18rpx;
}

.pet-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 2rpx solid #e1e7f0;
  border-radius: 26rpx;
  background: #ffffff;
}

.pet-card.complete {
  border-color: #32b36b;
  box-shadow: 0 10rpx 28rpx rgba(50, 179, 107, 0.1);
}

.pet-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.pet-title {
  font-size: 30rpx;
  font-weight: 700;
}

.complete-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eaf8ef;
  color: #128245;
  font-size: 22rpx;
  font-weight: 650;
}

.identity-grid,
.talent-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.talent-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.field-group {
  margin-top: 16rpx;
  padding: 18rpx 16rpx 10rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 18rpx;
}

.group-label {
  display: block;
  margin-bottom: 12rpx;
  color: #475467;
  font-size: 23rpx;
  font-weight: 650;
}

.detail-panel {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
}

.detail-heading {
  display: block;
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-item {
  margin-top: 12rpx;
}

.detail-item + .detail-item {
  padding-top: 12rpx;
  border-top: 1rpx solid #e4e9f0;
}

.detail-name,
.detail-description,
.skill-meta {
  display: block;
}

.detail-name {
  color: #1d2939;
  font-size: 25rpx;
  font-weight: 650;
}

.detail-description {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.55;
}

.skill-detail-head {
  display: block;
}

.skill-meta {
  margin-top: 4rpx;
  color: #475467;
  font-size: 20rpx;
}
