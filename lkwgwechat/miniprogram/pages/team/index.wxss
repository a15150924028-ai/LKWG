.team-toolbar {
  margin-top: 24rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.52);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0.44)), radial-gradient(circle at 90% 8%, rgba(108, 99, 255, 0.08), rgba(108, 99, 255, 0) 42%);
  box-shadow: 0 16rpx 40rpx rgba(80, 110, 160, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.90), inset 0 -1rpx 0 rgba(255, 255, 255, 0.36);
}

.team-progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.team-count {
  display: block;
  font-size: 28rpx;
  font-weight: 650;
}

.team-progress-percent {
  color: #5F6B7A;
  font-size: 23rpx;
  font-weight: 600;
}

.team-progress-track {
  height: 12rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(160, 180, 210, 0.22);
}

.team-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #46D8CF, #6C63FF);
  box-shadow: 0 6rpx 18rpx rgba(108, 99, 255, 0.24);
}

.toolbar-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.small-button {
  flex: 1;
  min-width: 190rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.48);
  color: #5F6B7A;
  font-size: 24rpx;
  font-weight: 600;
}

.small-button::after {
  border: 0;
}

.small-button.primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 0;
  background: linear-gradient(135deg, #7C6DFF 0%, #4DA3FF 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(108, 99, 255, 0.28);
}

.roller-button-icon {
  flex: none;
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
}

.small-button.danger {
  background: rgba(255, 107, 122, 0.10);
  color: #E85A6A;
}

.team-overview {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 20rpx;
}

.team-slot {
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  min-width: 0;
  min-height: 150rpx;
  margin: 0;
  padding: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.50);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.54), rgba(255, 255, 255, 0.42));
  box-shadow: 0 8rpx 22rpx rgba(80, 110, 160, 0.10), inset 0 1rpx 0 rgba(255, 255, 255, 0.88), inset 0 -1rpx 0 rgba(255, 255, 255, 0.32);
  color: #1F2633;
  line-height: 1.3;
  text-align: left;
}

.team-slot::after {
  border: 0;
}

.team-slot.active {
  border-color: rgba(77, 163, 255, 0.65);
  background: linear-gradient(135deg, rgba(108, 99, 255, 0.12), rgba(70, 216, 207, 0.10));
  box-shadow: inset 0 0 0 2rpx rgba(77, 163, 255, 0.45), inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.team-slot.complete {
  border-color: rgba(53, 212, 155, 0.42);
}

.team-slot.active.complete {
  border-color: #1677ff;
}

.team-slot-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.team-slot-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  color: #5F6B7A;
  font-size: 20rpx;
  font-weight: 700;
}

.team-slot.active .team-slot-number {
  background: linear-gradient(135deg, #6C63FF, #4DA3FF);
  color: #ffffff;
}

.team-slot-status {
  padding: 3rpx 9rpx;
  border-radius: 999rpx;
  background: rgba(53, 212, 155, 0.14);
  color: #1FAE7A;
  font-size: 18rpx;
  font-weight: 650;
}

.team-slot-name {
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  font-size: 23rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-slot-types {
  display: flex;
  flex-wrap: wrap;
  gap: 5rpx;
  margin-top: 8rpx;
}

.team-slot-type {
  padding: 2rpx 7rpx;
  border-radius: 999rpx;
  background: rgba(77, 163, 255, 0.13);
  color: #4DA3FF;
  font-size: 17rpx;
}

.team-slot-empty {
  color: #98a2b3;
  font-size: 18rpx;
}

.pet-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.52);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0.44)), radial-gradient(circle at 94% 0%, rgba(77, 163, 255, 0.08), rgba(77, 163, 255, 0) 42%);
  box-shadow: 0 16rpx 40rpx rgba(80, 110, 160, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.90), inset 0 -1rpx 0 rgba(255, 255, 255, 0.36);
}

.pet-card.complete {
  border-color: rgba(53, 212, 155, 0.42);
  box-shadow: 0 16rpx 40rpx rgba(53, 212, 155, 0.12), inset 0 1rpx 0 rgba(255, 255, 255, 0.90), inset 0 -1rpx 0 rgba(255, 255, 255, 0.36);
}

.pet-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.pet-title {
  font-size: 30rpx;
  font-weight: 700;
}

.complete-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(53, 212, 155, 0.28);
  background: rgba(53, 212, 155, 0.14);
  color: #1FAE7A;
  font-size: 22rpx;
  font-weight: 650;
}

.identity-grid,
.talent-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.talent-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.field-group {
  margin-top: 16rpx;
  padding: 18rpx 16rpx 10rpx;
  border: 1rpx solid rgba(190, 205, 225, 0.55);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.34);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.30));
}

.group-label {
  display: block;
  margin-bottom: 12rpx;
  color: #5F6B7A;
  font-size: 23rpx;
  font-weight: 650;
}

.detail-panel {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(190, 205, 225, 0.55);
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.50), rgba(255, 255, 255, 0.38));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86), inset 0 -1rpx 0 rgba(255, 255, 255, 0.30);
}

.detail-heading {
  display: block;
  color: #5F6B7A;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-item {
  margin-top: 12rpx;
}

.detail-item + .detail-item {
  padding-top: 12rpx;
  border-top: 1rpx solid #e4e9f0;
}

.detail-name,
.detail-description,
.skill-meta {
  display: block;
}

.detail-name {
  color: #1F2633;
  font-size: 25rpx;
  font-weight: 650;
}

.detail-description {
  margin-top: 6rpx;
  color: #5F6B7A;
  font-size: 23rpx;
  line-height: 1.55;
}

.skill-detail-head {
  display: block;
}

.skill-meta {
  margin-top: 4rpx;
  color: #5F6B7A;
  font-size: 20rpx;
}
