<page-meta page-style="{{pickerScrollLocked ? 'overflow: hidden;' : ''}}" />
<view class="page">
  <view class="hero">
    <text class="hero-title">阵容分析</text>
    <text class="hero-description">查看队伍属性覆盖、弱点、抗性与配置完成情况。</text>
  </view>

  <view wx:if="{{result.configuredCount === 0}}" class="status-card">
    <text class="status-title">暂无队伍配置</text>
    <text class="status-text">先在队伍页选择精灵和技能，本页会自动读取并生成分析。</text>
    <button class="primary-button" bindtap="goToTeam">前往队伍</button>
  </view>

  <view class="analysis-card roller-target-card">
    <text class="card-title">过山车目标</text>
    <view class="roller-slot-grid">
      <view
        wx:for="{{rollerSlots}}"
        wx:key="slot"
        wx:for-item="slot"
        class="roller-target-slot {{slot.hasMonster ? '' : 'empty'}}"
      >
        <view class="roller-target-head">
          <text class="roller-target-index">{{slot.slot + 1}}</text>
          <view class="roller-target-title">
            <text class="roller-target-name">{{slot.title}}</text>
            <text class="roller-target-monster">{{slot.monsterName}}</text>
          </view>
        </view>
        <field-picker
          compact
          label="目标技能"
          options="{{slot.skillOptions}}"
          value-index="{{slot.rollerSelection.index}}"
          value-label="{{slot.rollerSelection.label}}"
          data-pet-index="{{slot.slot}}"
          data-picker-handler="onRollerSkillChange"
          bind:change="onRollerSkillChange"
          bind:open="onPickerOpen"
        />
        <view
          class="roller-learner-card {{slot.learnerHasMore ? 'expandable' : ''}}"
          data-slot="{{slot.slot}}"
          bindtap="onToggleLearners"
        >
          <view class="roller-learner-head">
            <text class="roller-learner-title">谁能学 · {{slot.learnerCount}}</text>
          </view>
          <text class="roller-learner-text {{slot.learnerExpanded ? 'expanded' : ''}}">
            {{slot.learnerExpanded ? slot.learnerFullText : slot.learnerPreview}}
          </text>
        </view>
      </view>
    </view>
  </view>

  <block wx:if="{{result.configuredCount > 0}}">
    <view class="summary-grid">
      <view class="summary-card">
        <text class="summary-value">{{result.configuredCount}}/6</text>
        <text class="summary-label">已选择精灵</text>
      </view>
      <view class="summary-card">
        <text class="summary-value">{{result.completeCount}}/6</text>
        <text class="summary-label">配置完成</text>
      </view>
    </view>

    <view class="analysis-card">
      <text class="card-title">当前克制面</text>
      <view class="type-chip-list">
        <block wx:for="{{result.coveredTypeChips}}" wx:key="id" wx:for-item="type">
          <view class="type-chip">
            <image class="type-chip-icon {{type.iconClass}}" src="{{type.icon}}" mode="aspectFit" />
            <text>{{type.name}}</text>
          </view>
        </block>
        <text wx:if="{{!result.coveredTypeChips.length}}" class="tag-text">暂无</text>
      </view>
      <text class="card-title secondary">尚未覆盖</text>
      <view class="type-chip-list warning">
        <block wx:for="{{result.missingTypeChips}}" wx:key="id" wx:for-item="type">
          <view class="type-chip">
            <image class="type-chip-icon {{type.iconClass}}" src="{{type.icon}}" mode="aspectFit" />
            <text>{{type.name}}</text>
          </view>
        </block>
        <text wx:if="{{!result.missingTypeChips.length}}" class="tag-text warning">无</text>
      </view>
    </view>

    <block wx:for="{{result.monsters}}" wx:key="id" wx:for-item="monster">
      <view class="analysis-card">
        <view class="monster-head">
          <view>
            <text class="monster-name">{{monster.name}}</text>
            <view class="type-chip-list compact">
              <block wx:for="{{monster.typeChips}}" wx:key="id" wx:for-item="type">
                <view class="type-chip">
                  <image class="type-chip-icon {{type.iconClass}}" src="{{type.icon}}" mode="aspectFit" />
                  <text>{{type.name}}</text>
                </view>
              </block>
            </view>
          </view>
          <text class="state-badge {{monster.complete ? 'complete' : ''}}">
            {{monster.complete ? '配置完成' : '配置未完成'}}
          </text>
        </view>

        <view class="stat-grid">
          <block wx:for="{{monster.statRows}}" wx:key="label" wx:for-item="stat">
            <view class="stat-cell">
              <text class="stat-label">{{stat.label}}</text>
              <text class="stat-value">{{stat.value}}</text>
            </view>
          </block>
        </view>

        <text class="card-title secondary">主要弱点</text>
        <view class="type-chip-list warning">
          <block wx:for="{{monster.weaknessChips}}" wx:key="id" wx:for-item="type">
            <view class="type-chip">
              <image class="type-chip-icon {{type.iconClass}}" src="{{type.icon}}" mode="aspectFit" />
              <text>{{type.name}}</text>
            </view>
          </block>
          <text wx:if="{{!monster.weaknessChips.length}}" class="tag-text warning">无</text>
        </view>
        <text class="card-title secondary">抗性</text>
        <view class="type-chip-list good">
          <block wx:for="{{monster.resistanceChips}}" wx:key="id" wx:for-item="type">
            <view class="type-chip">
              <image class="type-chip-icon {{type.iconClass}}" src="{{type.icon}}" mode="aspectFit" />
              <text>{{type.name}}</text>
            </view>
          </block>
          <text wx:if="{{!monster.resistanceChips.length}}" class="tag-text good">无</text>
        </view>
      </view>
    </block>
  </block>
  <floating-picker
    visible="{{floatingPicker.visible}}"
    label="{{floatingPicker.label}}"
    options="{{floatingPicker.options}}"
    value-index="{{floatingPicker.valueIndex}}"
    value-label="{{floatingPicker.valueLabel}}"
    bind:select="onFloatingPickerSelect"
    bind:close="onFloatingPickerClose"
  />
</view>
