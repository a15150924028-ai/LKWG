.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.summary-card,
.analysis-card {
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.52);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.58), rgba(255, 255, 255, 0.44)), radial-gradient(circle at 94% 0%, rgba(77, 163, 255, 0.08), rgba(77, 163, 255, 0) 42%);
  box-shadow: 0 16rpx 40rpx rgba(80, 110, 160, 0.16), inset 0 1rpx 0 rgba(255, 255, 255, 0.90), inset 0 -1rpx 0 rgba(255, 255, 255, 0.36);
}

.analysis-card {
  margin-top: 20rpx;
}

.summary-value,
.summary-label {
  display: block;
}

.summary-value {
  color: #6C63FF;
  font-size: 36rpx;
  font-weight: 750;
}

.summary-label {
  margin-top: 6rpx;
  color: #5F6B7A;
  font-size: 23rpx;
}

.card-title {
  display: block;
  color: #1F2633;
  font-size: 28rpx;
  font-weight: 700;
}

.card-title.secondary {
  margin-top: 20rpx;
  font-size: 24rpx;
}

.roller-target-card {
  padding-bottom: 20rpx;
}

.team-score-card {
  background: linear-gradient(135deg, rgba(77, 163, 255, 0.13), rgba(70, 216, 207, 0.12));
}

.team-score-grid {
  display: grid;
  gap: 14rpx;
  margin-top: 16rpx;
}

.team-score-row {
  display: grid;
  grid-template-columns: 130rpx minmax(0, 1fr) 70rpx;
  align-items: center;
  gap: 12rpx;
  color: #5F6B7A;
  font-size: 23rpx;
  font-weight: 600;
}

.team-score-bar {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(160, 180, 210, 0.22);
}

.team-score-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #46D8CF, #6C63FF);
}

.team-score-fill.strong {
  background: linear-gradient(90deg, #4DA3FF, #8B7CFF);
}

.roller-slot-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.roller-target-slot {
  box-sizing: border-box;
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-left: 8rpx solid rgba(77, 163, 255, 0.42);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.46);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.50), rgba(255, 255, 255, 0.38));
  box-shadow: 0 8rpx 22rpx rgba(80, 110, 160, 0.10), inset 0 1rpx 0 rgba(255, 255, 255, 0.86), inset 0 -1rpx 0 rgba(255, 255, 255, 0.28);
}

.roller-target-slot.empty {
  opacity: 0.72;
}

.roller-target-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.roller-target-index {
  flex: none;
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, rgba(108, 99, 255, 0.16), rgba(70, 216, 207, 0.16));
  color: #4DA3FF;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
}

.roller-target-title {
  min-width: 0;
}

.roller-target-name,
.roller-target-monster {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.roller-target-name {
  color: #1F2633;
  font-size: 25rpx;
  font-weight: 750;
}

.roller-target-monster {
  margin-top: 2rpx;
  color: #5F6B7A;
  font-size: 21rpx;
}

.roller-learner-card {
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.44);
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.48), rgba(255, 255, 255, 0.36));
}

.roller-learner-card.expandable {
  border: 1rpx solid rgba(77, 163, 255, 0.18);
}

.roller-learner-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.roller-learner-title {
  display: block;
  min-width: 0;
  color: #4DA3FF;
  font-size: 21rpx;
  font-weight: 700;
}

.roller-learner-chevron {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  margin-right: 4rpx;
  border-right: 3rpx solid #98a2b3;
  border-bottom: 3rpx solid #98a2b3;
  transform: rotate(45deg);
  transition: transform 0.18s ease;
}

.roller-learner-chevron.expanded {
  transform: rotate(225deg);
}

.roller-learner-text {
  display: block;
  overflow: hidden;
  min-width: 0;
  margin-top: 0;
  color: #5F6B7A;
  font-size: 22rpx;
  line-height: 1.35;
  white-space: nowrap;
  text-overflow: ellipsis;
  -webkit-line-clamp: 1;
}

.roller-learner-text.expanded {
  overflow: visible;
  white-space: normal;
  text-overflow: clip;
  -webkit-line-clamp: initial;
}

.tag-text {
  display: block;
  margin-top: 10rpx;
  color: #1F2633;
  font-size: 25rpx;
  line-height: 1.6;
}

.tag-text.warning {
  color: #D6811F;
}

.tag-text.good {
  color: #1FAE7A;
}

.type-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.type-chip-list.compact {
  margin-top: 8rpx;
}

.type-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(77, 163, 255, 0.13);
  color: #4DA3FF;
  font-size: 25rpx;
  line-height: 1.4;
}

.type-chip-list.warning .type-chip {
  background: rgba(255, 180, 92, 0.15);
  color: #D6811F;
}

.type-chip-list.good .type-chip {
  background: rgba(53, 212, 155, 0.14);
  color: #1FAE7A;
}

.type-chip-icon {
  flex: none;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
}

.monster-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.monster-name,
.monster-types {
  display: block;
}

.monster-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2633;
}

.monster-types {
  margin-top: 5rpx;
  color: #5F6B7A;
  font-size: 23rpx;
}

.state-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 180, 92, 0.15);
  color: #D6811F;
  font-size: 21rpx;
}

.state-badge.complete {
  border: 1rpx solid rgba(53, 212, 155, 0.28);
  background: rgba(53, 212, 155, 0.14);
  color: #1FAE7A;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 20rpx;
}

.stat-cell {
  padding: 12rpx 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.46);
  text-align: center;
  background-image: linear-gradient(135deg, rgba(255, 255, 255, 0.50), rgba(255, 255, 255, 0.38));
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.86), inset 0 -1rpx 0 rgba(255, 255, 255, 0.28);
}

.stat-label,
.stat-value {
  display: block;
}

.stat-label {
  color: #5F6B7A;
  font-size: 20rpx;
}

.stat-value {
  margin-top: 4rpx;
  font-size: 27rpx;
  font-weight: 700;
  color: #1F2633;
}
