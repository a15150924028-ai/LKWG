.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.summary-card,
.analysis-card {
  padding: 24rpx;
  border: 1rpx solid #e0e7f0;
  border-radius: 22rpx;
  background: #ffffff;
}

.analysis-card {
  margin-top: 20rpx;
}

.summary-value,
.summary-label {
  display: block;
}

.summary-value {
  color: #1677ff;
  font-size: 36rpx;
  font-weight: 750;
}

.summary-label {
  margin-top: 6rpx;
  color: #667085;
  font-size: 23rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.card-title.secondary {
  margin-top: 20rpx;
  font-size: 24rpx;
}

.roller-target-card {
  padding-bottom: 20rpx;
}

.roller-slot-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.roller-target-slot {
  box-sizing: border-box;
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid #dfe6ef;
  border-left: 8rpx solid #d0dce9;
  border-radius: 14rpx;
  background: #f8fafc;
}

.roller-target-slot.empty {
  opacity: 0.72;
}

.roller-target-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.roller-target-index {
  flex: none;
  width: 42rpx;
  height: 42rpx;
  border-radius: 12rpx;
  background: #e8f7f7;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
}

.roller-target-title {
  min-width: 0;
}

.roller-target-name,
.roller-target-monster {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.roller-target-name {
  color: #172033;
  font-size: 25rpx;
  font-weight: 750;
}

.roller-target-monster {
  margin-top: 2rpx;
  color: #667085;
  font-size: 21rpx;
}

.roller-learner-card {
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.roller-learner-card.expandable {
  border: 1rpx solid #e6eef8;
}

.roller-learner-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.roller-learner-title {
  display: block;
  min-width: 0;
  color: #1677ff;
  font-size: 21rpx;
  font-weight: 700;
}

.roller-learner-chevron {
  flex: none;
  width: 14rpx;
  height: 14rpx;
  margin-right: 4rpx;
  border-right: 3rpx solid #98a2b3;
  border-bottom: 3rpx solid #98a2b3;
  transform: rotate(45deg);
  transition: transform 0.18s ease;
}

.roller-learner-chevron.expanded {
  transform: rotate(225deg);
}

.roller-learner-text {
  display: block;
  overflow: hidden;
  min-width: 0;
  margin-top: 0;
  color: #475467;
  font-size: 22rpx;
  line-height: 1.35;
  white-space: nowrap;
  text-overflow: ellipsis;
  -webkit-line-clamp: 1;
}

.roller-learner-text.expanded {
  overflow: visible;
  white-space: normal;
  text-overflow: clip;
  -webkit-line-clamp: initial;
}

.tag-text {
  display: block;
  margin-top: 10rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.6;
}

.tag-text.warning {
  color: #b54708;
}

.tag-text.good {
  color: #128245;
}

.type-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.type-chip-list.compact {
  margin-top: 8rpx;
}

.type-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.4;
}

.type-chip-list.warning .type-chip {
  color: #b54708;
}

.type-chip-list.good .type-chip {
  color: #128245;
}

.type-chip-icon {
  flex: none;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
}

.monster-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.monster-name,
.monster-types {
  display: block;
}

.monster-name {
  font-size: 30rpx;
  font-weight: 700;
}

.monster-types {
  margin-top: 5rpx;
  color: #667085;
  font-size: 23rpx;
}

.state-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #fff4e5;
  color: #b54708;
  font-size: 21rpx;
}

.state-badge.complete {
  background: #eaf8ef;
  color: #128245;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 20rpx;
}

.stat-cell {
  padding: 12rpx 8rpx;
  border-radius: 14rpx;
  background: #f5f7fb;
  text-align: center;
}

.stat-label,
.stat-value {
  display: block;
}

.stat-label {
  color: #667085;
  font-size: 20rpx;
}

.stat-value {
  margin-top: 4rpx;
  font-size: 27rpx;
  font-weight: 700;
}
