.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 9rpx;
  margin-top: 16rpx;
}

.stat-cell {
  min-width: 0;
  padding: 11rpx 8rpx;
  border-radius: 13rpx;
  background: #f5f7fb;
  text-align: center;
}

.stat-cell.nature-up {
  background: #eaf8ef;
}

.stat-cell.nature-down {
  box-shadow: inset 0 0 0 2rpx #f5b7b1;
}

.stat-label-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rpx;
  color: #667085;
  font-size: 20rpx;
}

.stat-value {
  display: block;
  margin-top: 3rpx;
  font-size: 28rpx;
  font-weight: 720;
}

.nature-arrow,
.talent-mark {
  font-weight: 900;
}

.nature-arrow.up,
.talent-mark {
  color: #128245;
}

.nature-arrow.down {
  color: #d92d20;
}

.talent-mark {
  font-size: 25rpx;
}
