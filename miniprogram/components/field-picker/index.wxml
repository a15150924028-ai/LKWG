<view class="field-picker {{compact ? 'compact' : ''}} {{disabled ? 'disabled' : ''}}">
  <text class="field-label">{{label}}</text>
  <picker
    mode="selector"
    range="{{options}}"
    range-key="label"
    value="{{valueIndex}}"
    disabled="{{disabled}}"
    bindchange="onPickerChange"
  >
    <view class="field-value">
      <text class="{{valueIndex === 0 ? 'placeholder' : ''}}">{{valueLabel}}</text>
      <text class="chevron">⌄</text>
    </view>
  </picker>
</view>
